# ==== AI API 配置 ====

AI_API_KEY=your-api-key
# 你的 API 密钥（必填）。也兼容 DEEPSEEK_API_KEY / OPENAI_API_KEY。

AI_BASE_URL=https://api.deepseek.com
# API 地址。兼容所有 OpenAI Chat Completions 格式的提供商。

AI_MODEL=deepseek-v4-flash
# 模型名称。开启 AI_VISION_ENABLED 后需改为支持多模态的模型（如 gpt-4o）。

AI_TEMPERATURE=0.2
# 生成温度。解析题目建议保持低值（0.1~0.3），太高容易胡编。

AI_MAX_TOKENS=2000
# 每次请求最大 token 数。

# 思考模式（enabled / disabled）。
# ⚠️ deepseek会与 response_format=json_object 互斥，开启后需在代码中移除该配置。
# 当前场景（选择题解析）不需要思考模式，建议保持关闭，若要开启请确保思考模式和json输出不互斥。
AI_THINKING=disabled

# ==== 图片识别 ====

# 是否将题目图片发送给 AI（要求 AI_MODEL 支持多模态）。
# 默认关闭，开启前请确认模型支持 image_url 输入。
AI_VISION_ENABLED=false
# 每道题最多发送的图片数量。
AI_VISION_MAX_IMAGES=4

# ==== 答案校验 ====

# 是否让 AI 独立校验导出答案的正确性，在复核清单中标记风险题目。
# 可通过 CLI 参数 --verify-answers 临时覆盖。
VERIFY_ANSWERS=false

# ==== 文档输出 ====

DOCX_FONT=Microsoft YaHei
# Word 文档字体。
